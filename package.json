{
  "name": "@max/source",
  "version": "0.0.0",
  "packageManager": "pnpm@10.11.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm nx run-many -t serve -p web api worker --parallel=3",
    "build": "pnpm nx run-many -t build -p web api worker --parallel=3",
    "lint": "pnpm nx run-many -t lint --parallel=3",
    "lint:fix": "pnpm nx run-many -t lint --parallel=3 -- --fix",
    "format": "pnpm nx format:write --all",
    "format:check": "pnpm nx format:check --all",
    "db:up": "docker-compose up -d postgres redis",
    "db:down": "docker-compose down",
    "verify:connectivity": "node ./scripts/verify-connectivity.mjs",
    "test:integration": "pnpm nx run api:integration && pnpm nx run worker:integration",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema apps/api/prisma/schema.prisma",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/esbuild": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/nest": "22.7.2",
    "@nx/node": "22.7.2",
    "@nx/react": "^22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/web": "22.7.2",
    "@nx/webpack": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/ui": "~4.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "lint-staged": "^17.0.5",
    "nx": "22.7.2",
    "prettier": "~3.6.2",
    "prisma": "^6.11.1",
    "supertest": "^7.2.2",
    "swc-loader": "^0.2.7",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "tsx": "^4.22.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.7",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.13",
    "@tanstack/react-query-devtools": "^5.100.13",
    "assistant-ui": "^0.0.92",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^5.9.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.6.0"
  }
}
